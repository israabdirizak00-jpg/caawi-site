      <span style={{ display: "inline-flex", alignItems: "center", gap: "5px" }}>
        <span style={{ width: "6px", height: "6px", borderRadius: "50%", background: "#2ABBA8", boxShadow: "0 0 6px #2ABBA8aa" }} />
        <span style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: "10px", letterSpacing: "0.15em", textTransform: "uppercase", color: "#2ABBA8" }}>
          Live
        </span>
      </span>
    </div>
    <div style={{ display: "flex", gap: "32px" }}>
      {[
        { val: "1,338",  label: "Total Users"       },
        { val: "7",      label: "Active Cities"     },
        { val: CROSS_LINKS.length, label: "Cross-City Links" },
        { val: Object.values(CITY_BOARDS).flat().length, label: "Board Posts" },
      ].map((s, i) => (
        <div key={i} style={{ textAlign: "right" }}>
          <div style={{ fontFamily: "'Cormorant Garamond', serif", fontSize: "22px", fontWeight: 700, color: "#D4A843", lineHeight: 1 }}>
            {s.val}
          </div>
          <div style={{ fontFamily: "'Barlow Condensed', sans-serif", fontSize: "9px", letterSpacing: "0.14em", textTransform: "uppercase", color: "rgba(255,255,255,0.2)", marginTop: "2px" }}>
            {s.label}
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* ── BODY ── */}
  <div style={{ display: "flex", flex: 1, minHeight: 0 }}>

    {/* MAP */}
    <div style={{ flex: 1, position: "relative" }}>
      {/* Filter bar */}
      <div style={{ position: "absolute", top: "14px", left: "14px", zIndex: 20, display: "flex", gap: "5px" }}>
        {["All", "Employment", "Legal Aid", "Housing", "Healthcare", "Community"].map(cat => {
          const color = CAT_COLOR[cat] || "#D4A843";
          const isA = filter === cat;
          return (
            <button key={cat} onClick={() => setFilter(cat)} style={{
              padding: "4px 12px",
              border: `1px solid ${isA ? color : "rgba(255,255,255,0.07)"}`,
              borderRadius: "1px",
              background: isA ? `${color}14` : "rgba(8,6,8,0.85)",
              color: isA ? color : "rgba(255,255,255,0.28)",
              fontFamily: "'Barlow Condensed', sans-serif",
              fontSize: "9px", letterSpacing: "0.15em", textTransform: "uppercase",
              cursor: "pointer", transition: "all 0.15s", fontWeight: 600,
            }}>
              {cat}
            </button>
          );
        })}
      </div>

      {/* Click-city hint */}
      <div style={{
        position: "absolute", bottom: "14px", left: "14px", zIndex: 20,
        fontFamily: "'Barlow Condensed', sans-serif",
        fontSize: "9px", letterSpacing: "0.15em", textTransform: "uppercase",
        color: "rgba(255,255,255,0.15)",
      }}>
        Click a city to filter connections · Double-click to open city board
      </div>

      <svg viewBox="0 0 100 78" style={{ width: "100%", height: "100%", minHeight: "500px", display: "block" }}
           preserveAspectRatio="xMidYMid meet">
        <defs>
          <pattern id="grid" x="0" y="0" width="4" height="4" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="0.16" fill="rgba(212,168,67,0.10)" />
          </pattern>
          <radialGradient id="homeGlow" cx="42%" cy="40%" r="22%">
            <stop offset="0%"   stopColor="#D4A843" stopOpacity="0.06" />
            <stop offset="100%" stopColor="#D4A843" stopOpacity="0" />
          </radialGradient>
          <filter id="blur-soft">
            <feGaussianBlur stdDeviation="0.5" />
          </filter>
        </defs>
        <rect width="100" height="78" fill="#080608" />
        <rect width="100" height="78" fill="url(#grid)" />
        <rect width="100" height="78" fill="url(#homeGlow)" />

        {/* Arcs */}
        {visibleLinks.map((link, i) => {
          const f = cityMap[link.from], t = cityMap[link.to];
          if (!f || !t) return null;
          const col = CAT_COLOR[link.category] || "#D4A843";
          const isHov = hovered === link.id;
          const speed = 1.2 + (link.id % 5) * 0.3;
          const path = curvePath(f.x, f.y, t.x, t.y);
          return (
            <g key={link.id}
               onMouseEnter={() => setHovered(link.id)}
               onMouseLeave={() => setHovered(null)}>
              <path d={path} fill="none" stroke={col}
                strokeWidth={isHov ? "0.9" : "0.4"} strokeOpacity={isHov ? 0.2 : 0.08} />
              <path d={path} fill="none" stroke={col}
                strokeWidth={isHov ? "0.35" : "0.18"} strokeOpacity={isHov ? 1 : 0.55}
                strokeDasharray="2.2 3.8"
                style={{ animation: `dash ${speed}s linear infinite` }} />
            </g>
          );
        })}

        {/* Nodes */}
        {CITIES.map(city => {
          const isActive = activeCity === city.id;
          const hasConn = visibleLinks.some(l => l.from === city.id || l.to === city.id);
          const dimmed = activeCity && !hasConn && !isActive;
          const r = city.isHome ? 1.6 : Math.max(0.7, Math.min(1.2, city.users / 160));
          const col = city.isHome ? "#D4A843" : isActive ? "#D4A843" : "#2ABBA8";
          const hasBoard = (CITY_BOARDS[city.id] || []).length > 0;

          return (
            <g key={city.id}
               style={{ opacity: dimmed ? 0.25 : 1, transition: "opacity 0.2s", cursor: "pointer" }}
               className={city.isHome ? "home-node" : ""}
               onClick={() => setActiveCity(isActive ? null : city.id)}
               onDoubleClick={() => setPanelCity(city)}
            >
              {/* Rings */}
              <circle cx={city.x} cy={city.y} r={r + 1.8} fill="none"
                stroke={col} strokeWidth="0.1" strokeOpacity={isActive || city.isHome ? 0.3 : 0.06} />
              <circle cx={city.x} cy={city.y} r={r + 0.8} fill="none"
                stroke={col} strokeWidth="0.1" strokeOpacity={isActive || city.isHome ? 0.18 : 0.04} />
              {/* Node */}
              <circle cx={city.x} cy={city.y} r={r}
                fill={isActive || city.isHome ? `${col}22` : `${col}0e`}
                stroke={col} strokeWidth="0.22" />
              {/* Core */}
              <circle cx={city.x} cy={city.y} r={r * 0.38}
                fill={col} fillOpacity={isActive || city.isHome ? 1 : 0.75} />
              {/* Board indicator dot */}
              {hasBoard && (
                <circle cx={city.x + r * 0.88} cy={city.y - r * 0.88} r="0.38"
                  fill="#D4A843" fillOpacity="0.9" />
              )}
              {/* City name */}
              <text x={city.x} y={city.y - r - 1.1} textAnchor="middle" style={{
                fontSize: city.isHome ? "1.8px" : "1.45px",
                fill: isActive ? "#D4A843" : city.isHome ? "#D4A843" : "rgba(242,237,228,0.72)",
                fontWeight: city.isHome || isActive ? 700 : 400,
                fontFamily: "'Barlow Condensed', sans-serif",
                letterSpacing: "0.05em", textTransform: "uppercase",
              }}>
                {city.name}
              </text>
              {/* Users */}
              <text x={city.x} y={city.y + r + 1.9} textAnchor="middle" style={{
                fontSize: "1.1px", fill: "rgba(255,255,255,0.22)", fontFamily: "monospace",
              }}>
                {city.users.toLocaleString()} users
              </text>
              {/* Board count */}
              {hasBoard && (
                <text x={city.x} y={city.y + r + 3.2} textAnchor="middle" style={{
                  fontSize: "1.0px", fill: "#D4A84388", fontFamily: "'Barlow Condensed', sans-serif",
                  letterSpacing: "0.04em",
                }}>
                  {(CITY_BOARDS[city.id] || []).length} board posts
                </text>
              )}
            </g>
          );
        })}
      </svg>
    </div>

    {/* SIDEBAR */}
    <div style={{
      width: "300px",
      borderLeft: "1px solid rgba(255,255,255,0.05)",
      background: "#0b090b",
      display: "flex", flexDirection: "column",
      flexShrink: 0,
    }}>
      {/* Sidebar header */}
      <div style={{ padding: "18px 18px 14px", borderBottom: "1px solid rgba(255,255,255,0.04)", flexShrink: 0 }}>
        <div style={{
          fontFamily: "'Barlow Condensed', sans-serif",
          fontSize: "9px", letterSpacing: "0.2em", textTransform: "uppercase",
          color: "rgba(255,255,255,0.18)", marginBottom: "3px",
        }}>
          Live Connections
        </div>
        <div style={{
          fontFamily: "'Cormorant Garamond', serif",
          fontSize: "14px", fontWeight: 300, fontStyle: "italic",
          color: "rgba(242,237,228,0.4)",
        }}>
          Cross-city activity feed
        </div>
      </div>

      {/* Feed */}
      <div style={{ flex: 1, overflowY: "auto" }}>
        {visibleLinks.map((item, i) => {
          const f = cityMap[item.from], t = cityMap[item.to];
          const col = CAT_COLOR[item.category] || "#D4A843";
          return (
            <div key={item.id}
              onMouseEnter={() => setHovered(item.id)}
              onMouseLeave={() => setHovered(null)}
              style={{
                padding: "12px 18px",
                borderBottom: "1px solid rgba(255,255,255,0.03)",
                borderLeft: `2px solid ${hovered === item.id ? col : "transparent"}`,
                background: hovered === item.id ? "rgba(255,255,255,0.02)" : "transparent",
                transition: "all 0.15s", cursor: "default",
              }}>
              <div style={{ display: "flex", justifyContent: "space-between", marginBottom: "5px" }}>
                <span style={{
                  fontFamily: "'Barlow Condensed', sans-serif",
                  fontSize: "9px", letterSpacing: "0.14em", textTransform: "uppercase",
                  color: col, fontWeight: 600,
                  padding: "1px 6px", border: `1px solid ${col}30`, background: `${col}0e`,
                }}>
                  {item.category}
                </span>
                <span style={{ fontFamily: "monospace", fontSize: "9px", color: "rgba(255,255,255,0.16)" }}>
                  {item.time}
                </span>
              </div>
              <div style={{ fontSize: "12px", color: "rgba(242,237,228,0.65)", marginBottom: "5px", lineHeight: 1.4 }}>
                {item.desc}
              </div>
              <div style={{ display: "flex", gap: "5px", alignItems: "center", fontFamily: "'Barlow Condensed', sans-serif", fontSize: "10px" }}>
                <span style={{ color: "rgba(255,255,255,0.4)", letterSpacing: "0.04em" }}>{f?.name}</span>
                <span style={{ color: col }}>→</span>
                <span style={{ color: "rgba(255,255,255,0.4)", letterSpacing: "0.04em" }}>{t?.name}</span>
              </div>
            </div>
          );
        })}
      </div>

      {/* City board entry points */}
      <div style={{ padding: "16px 18px", borderTop: "1px solid rgba(255,255,255,0.04)", flexShrink: 0 }}>
        <div style={{
          fontFamily: "'Barlow Condensed', sans-serif",
          fontSize: "9px", letterSpacing: "0.2em", textTransform: "uppercase",
          color: "rgba(255,255,255,0.16)", marginBottom: "12px",
        }}>
          City Employment Boards
        </div>
        {CITIES.filter(c => (CITY_BOARDS[c.id] || []).length > 0).map(city => (
          <button key={city.id} onClick={() => setPanelCity(city)} style={{
            display: "flex", justifyContent: "space-between", alignItems: "center",
            width: "100%", padding: "9px 12px", marginBottom: "5px",
            background: "rgba(255,255,255,0.02)",
            border: "1px solid rgba(255,255,255,0.06)",
            borderRadius: "1px", cursor: "pointer",
            transition: "all 0.15s",
          }}
          onMouseEnter={e => { e.currentTarget.style.borderColor = "rgba(212,168,67,0.25)"; e.currentTarget.style.background = "rgba(212,168,67,0.04)"; }}
          onMouseLeave={e => { e.currentTarget.style.borderColor = "rgba(255,255,255,0.06)"; e.currentTarget.style.background = "rgba(255,255,255,0.02)"; }}
          >
            <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
              <div style={{
                width: "6px", height: "6px", borderRadius: "50%",
                background: city.isHome ? "#D4A843" : "#2ABBA8",
              }} />
              <span style={{
                fontFamily: "'Barlow Condensed', sans-serif",
                fontSize: "11px", letterSpacing: "0.06em", textTransform: "uppercase",
                color: "rgba(242,237,228,0.6)", fontWeight: 500,
              }}>
                {city.name}
              </span>
            </div>
            <span style={{
              fontFamily: "monospace", fontSize: "10px",
              color: "#D4A843", fontWeight: 600,
            }}>
              {(CITY_BOARDS[city.id] || []).length} posts →
            </span>
          </button>
        ))}
      </div>

      {/* Privacy */}
      <div style={{
        padding: "10px 18px",
        borderTop: "1px solid rgba(255,255,255,0.03)",
        background: "rgba(0,0,0,0.2)",
        flexShrink: 0,
      }}>
        <div style={{
          fontFamily: "'Barlow Condensed', sans-serif",
          fontSize: "9px", letterSpacing: "0.1em", textTransform: "uppercase",
          color: "rgba(255,255,255,0.1)", lineHeight: 1.7,
        }}>
          🔒 All posts anonymized · No individual identifiers · Aggregated city data only
        </div>
      </div>
    </div>
  </div>
</div>

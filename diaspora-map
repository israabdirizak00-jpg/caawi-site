function curvePath(x1, y1, x2, y2) {
const mx = (x1+x2)/2, my = (y1+y2)/2;
const dx = x2-x1, dy = y2-y1, len = Math.sqrt(dx*dx+dy*dy);
const offset = Math.min(len*0.18, 5);
return `M ${x1} ${y1} Q ${mx-(dy/len)*offset} ${my+(dx/len)*offset} ${x2} ${y2}`;
}

